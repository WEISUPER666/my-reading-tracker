# ==========================================
# AI 阅读助手配置
# ==========================================
# 复制此文件为 .env 并填入你的真实配置
# 注意：也可通过系统设置界面配置（优先级更高），两者只需配置其一

# AI 服务商（可选，默认 deepseek）
# 支持：deepseek / openai / gemini / ollama / custom
AI_PROVIDER=deepseek

# AI API Key（DeepSeek/OpenAI/Gemini 必填，Ollama 不需要）
AI_API_KEY=your_api_key_here

# AI 服务的 Base URL
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com/v1
# Gemini: https://generativelanguage.googleapis.com/v1beta/openai
# Ollama: http://localhost:11434/v1
AI_BASE_URL=https://api.deepseek.com

# 使用的模型名称
# DeepSeek: deepseek-chat / deepseek-reasoner
# OpenAI: gpt-4o / gpt-4o-mini / gpt-3.5-turbo
# Gemini: gemini-2.0-flash / gemini-2.5-flash / gemini-2.5-pro
# Ollama: qwen2.5:7b / llama3.1:8b / deepseek-r1:7b
AI_MODEL_NAME=deepseek-chat

# ==========================================
# 其他配置
# ==========================================

# 允许跨域访问的域名列表（逗号分隔）
# ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
